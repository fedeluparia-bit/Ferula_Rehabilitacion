<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FerulaSoftware.App.ViewModels"
             x:Class="FerulaSoftware.App.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#0D1117">

    <Grid>
        <Border Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="10"
                Padding="40,36"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel Spacing="22">

                <!-- Encabezado -->
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="🦾  Férula de Rehabilitación"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#E6EDF3"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sistema de Gestión Clínica — PoC v1.0"
                               FontSize="12" Foreground="#8B949E"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Separator Background="#30363D" Height="1"/>

                <!-- Correo -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Correo electrónico" Foreground="#C9D1D9" FontSize="13"/>
                    <TextBox Text="{Binding Email}"
                             Background="#0D1117"
                             Foreground="#E6EDF3"
                             BorderBrush="#30363D"
                             CornerRadius="5"
                             Padding="10,8"
                             FontSize="14"
                             Watermark="correo@ejemplo.com"
                             IsEnabled="{Binding !Cargando}"/>
                </StackPanel>

                <!-- Contraseña -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Contraseña" Foreground="#C9D1D9" FontSize="13"/>
                    <TextBox Text="{Binding Contrasena}"
                             PasswordChar="●"
                             Background="#0D1117"
                             Foreground="#E6EDF3"
                             BorderBrush="#30363D"
                             CornerRadius="5"
                             Padding="10,8"
                             FontSize="14"
                             Watermark="Ingresá tu contraseña"
                             IsEnabled="{Binding !Cargando}"/>
                </StackPanel>

                <!-- Error -->
                <Border Background="#2D1111" BorderBrush="#F85149" BorderThickness="1"
                        CornerRadius="5" Padding="10,7"
                        IsVisible="{Binding Error,
                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding Error}"
                               Foreground="#F85149" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Botón ingresar -->
                <Button Command="{Binding IngresarCommand}"
                        IsEnabled="{Binding !Cargando}"
                        Classes="btn-primary"
                        FontSize="15"
                        Margin="0,6,0,0">
                    <Panel>
                        <TextBlock Text="Ingresar"
                                   IsVisible="{Binding !Cargando}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Verificando..."
                                   IsVisible="{Binding Cargando}"
                                   Foreground="#8B949E"
                                   HorizontalAlignment="Center"/>
                    </Panel>
                </Button>

                <!-- Crear cuenta -->
                <Button Content="Crear cuenta nueva →"
                        Command="{Binding IrARegistroCommand}"
                        IsEnabled="{Binding !Cargando}"
                        Classes="btn-secondary"
                        FontSize="13"
                        HorizontalContentAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>

</UserControl>
