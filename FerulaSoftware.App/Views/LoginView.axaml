<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FerulaSoftware.App.ViewModels"
             x:Class="FerulaSoftware.App.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#0D1117">

    <!-- Tarjeta centrada en la pantalla -->
    <Grid>
        <Border Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="10"
                Padding="40,36"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel Spacing="22">

                <!-- Encabezado -->
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="🦾  Férula de Rehabilitación"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#E6EDF3"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sistema de Gestión Clínica — PoC v1.0"
                               FontSize="12" Foreground="#8B949E"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Separator Background="#30363D" Height="1"/>

                <!-- Usuario -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Usuario" Foreground="#C9D1D9" FontSize="13"/>
                    <TextBox Text="{Binding Usuario}"
                             Background="#0D1117"
                             Foreground="#E6EDF3"
                             BorderBrush="#30363D"
                             CornerRadius="5"
                             Padding="10,8"
                             FontSize="14"
                             Watermark="Ingrese su usuario"/>
                </StackPanel>

                <!-- Contraseña -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Contraseña" Foreground="#C9D1D9" FontSize="13"/>
                    <TextBox Text="{Binding Contrasena}"
                             PasswordChar="●"
                             Background="#0D1117"
                             Foreground="#E6EDF3"
                             BorderBrush="#30363D"
                             CornerRadius="5"
                             Padding="10,8"
                             FontSize="14"
                             Watermark="Ingrese su contraseña"/>
                </StackPanel>

                <!-- Botón ingresar -->
                <Button Content="Ingresar"
                        Command="{Binding IngresarCommand}"
                        Classes="btn-primary"
                        FontSize="15"
                        Margin="0,6,0,0"/>

                <!-- Footer -->
                <TextBlock Text="PoC — Acceso sin validación de credenciales"
                           FontSize="10" Foreground="#6E7681"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>

</UserControl>
