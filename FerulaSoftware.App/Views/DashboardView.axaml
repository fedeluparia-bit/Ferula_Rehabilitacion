<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FerulaSoftware.App.ViewModels"
             x:Class="FerulaSoftware.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Background="#0D1117">

    <Grid ColumnDefinitions="218,*">

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR                                                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#13171F"
                BorderBrush="#262D38"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- ── Cabecera: marca + usuario ───────────────────────────── -->
                <Border DockPanel.Dock="Top"
                        Padding="16,18,16,16"
                        BorderBrush="#262D38"
                        BorderThickness="0,0,0,1">
                    <StackPanel Spacing="14">

                        <!-- Logo con acento de marca a la izquierda -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="4" Height="32" CornerRadius="2"
                                    Background="{StaticResource BrandGradientV}"/>
                            <StackPanel Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="Férula PoC"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#F0F4F9"/>
                                <TextBlock Text="PANEL DE CONTROL"
                                           FontSize="9" Foreground="#6E7681"
                                           LetterSpacing="2" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Chip del usuario con avatar de gradiente -->
                        <Border Background="#0D1117"
                                BorderBrush="#262D38"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8,7">
                            <StackPanel Orientation="Horizontal" Spacing="9">
                                <Border CornerRadius="11" Width="24" Height="24"
                                        Background="{StaticResource BrandGradient}">
                                    <TextBlock Text="{Binding InicialUsuario}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Spacing="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding NombreUsuario}"
                                               Foreground="#E6EDF3"
                                               FontSize="12" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="Sesión activa"
                                               Foreground="#3FB950" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ── Cerrar Sesión (anclado al fondo) ────────────────────── -->
                <Button DockPanel.Dock="Bottom"
                        Content="↩   Cerrar Sesión"
                        Command="{Binding LogoutCommand}"
                        Classes="nav-btn"
                        Foreground="#E63946"
                        Margin="0,4,8,12"/>

                <!-- ── Mi Perfil (sobre el logout) ─────────────────────────── -->
                <Button DockPanel.Dock="Bottom"
                        Content="👤   Mi Perfil"
                        Command="{Binding NavegarAPerfilCommand}"
                        Classes="nav-btn"
                        Classes.active="{Binding PaginaActiva,
                            Converter={StaticResource Eq}, ConverterParameter=perfil}"
                        Margin="0,8,8,0"/>

                <!-- ── Ítems de navegación ─────────────────────────────────── -->
                <StackPanel Margin="0,18,8,0" Spacing="3">

                    <TextBlock Text="NAVEGACIÓN"
                               Classes="stat-label"
                               Margin="15,0,0,8"/>
                    <Button Content="📋   Sesión Libre"
                            Command="{Binding NavegarASesionLibreCommand}"
                            Classes="nav-btn"
                            Classes.active="{Binding PaginaActiva,
                                Converter={StaticResource Eq}, ConverterParameter=sesion}"/>
                    <Button Content="📅   Rutinas Programadas"
                            Command="{Binding NavegarARutinasProgramadasCommand}"
                            Classes="nav-btn"
                            Classes.active="{Binding PaginaActiva,
                                Converter={StaticResource Eq}, ConverterParameter=rutinas}"/>
                    <Button Content="📊   Ver Informes"
                            Command="{Binding NavegarAInformesCommand}"
                            Classes="nav-btn"
                            Classes.active="{Binding PaginaActiva,
                                Converter={StaticResource Eq}, ConverterParameter=informes}"/>

                    <Separator Background="#222A35" Margin="15,12,14,6"/>

                    <TextBlock Text="COMUNIDAD"
                               Classes="stat-label"
                               Margin="15,0,0,8"/>
                    <Button Content="📬   Bandeja de Entrada"
                            Command="{Binding NavegarABandejaEntradaCommand}"
                            Classes="nav-btn"
                            Classes.active="{Binding PaginaActiva,
                                Converter={StaticResource Eq}, ConverterParameter=bandeja}"/>
                    <Button Content="📤   Compartir Rutina"
                            Command="{Binding NavegarACompartirRutinaCommand}"
                            Classes="nav-btn"
                            Classes.active="{Binding PaginaActiva,
                                Converter={StaticResource Eq}, ConverterParameter=compartir}"/>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CONTENIDO INTERIOR                                                 -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding VistaInterior}"/>

    </Grid>

</UserControl>
