<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FerulaSoftware.App.ViewModels"
             x:Class="FerulaSoftware.App.Views.CompartirRutinaView"
             x:DataType="vm:CompartirRutinaViewModel"
             Background="#0D1117">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0,0,0,1"
                Padding="28,20">
            <StackPanel Spacing="4">
                <TextBlock Text="COMPARTIR RUTINA" Classes="page-eyebrow"/>
                <TextBlock Text="Envía un ejercicio a otro usuario" Classes="page-title"/>
            </StackPanel>
        </Border>

        <!-- ── Formulario ─────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" Padding="28,20,28,24">
            <StackPanel Spacing="20" MaxWidth="560">

                <!-- Correo del destinatario -->
                <StackPanel Spacing="10">
                    <TextBlock Text="CORREO DEL DESTINATARIO"
                               Foreground="#8B949E" FontSize="11" FontWeight="Bold"
                               LetterSpacing="1.5"/>
                    <TextBox Text="{Binding EmailDestinatario}"
                             Watermark="correo@paciente.com"
                             Background="#161B22" Foreground="#E6EDF3"
                             BorderBrush="#30363D" CornerRadius="5"
                             FontSize="13"/>
                    <TextBlock Text="El destinatario debe tener una cuenta registrada en el sistema."
                               Foreground="#6E7681" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>

                <Separator Background="#30363D" Height="1"/>

                <!-- Parámetros de la rutina -->
                <StackPanel Spacing="14">
                    <TextBlock Text="PARÁMETROS DE LA RUTINA"
                               Foreground="#8B949E" FontSize="11" FontWeight="Bold"
                               LetterSpacing="1.5"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Modo de rehabilitación"
                                   Foreground="#C9D1D9" FontSize="13"/>
                        <ComboBox SelectedIndex="{Binding ModoActivo}"
                                  HorizontalAlignment="Stretch"
                                  Background="#161B22" Foreground="#E6EDF3"
                                  BorderBrush="#30363D" CornerRadius="5" FontSize="13">
                            <ComboBoxItem Content="0 — Resistencia (activo-asistido)"/>
                            <ComboBoxItem Content="1 — Asistido (pasivo continuo)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Repeticiones objetivo"
                                   Foreground="#C9D1D9" FontSize="13"/>
                        <NumericUpDown Value="{Binding RepeticionesObjetivo}"
                                       Minimum="1" Maximum="99" Increment="1"
                                       Background="#161B22" Foreground="#E6EDF3"
                                       BorderBrush="#30363D" CornerRadius="5"
                                       FontSize="14" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </StackPanel>

                <Separator Background="#30363D" Height="1"/>

                <!-- Opción de terapeuta -->
                <StackPanel Spacing="8">
                    <CheckBox IsChecked="{Binding EsTerapeuta}"
                              Foreground="#C9D1D9" FontSize="13">
                        Enviar como Terapeuta Verificado
                    </CheckBox>
                    <TextBlock Text="El destinatario verá un badge '✔ Terapeuta' junto a tu nombre."
                               Foreground="#6E7681" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding EsTerapeuta}"/>
                </StackPanel>

                <!-- Mensaje de error -->
                <Border Background="#2D1111" BorderBrush="#F85149" BorderThickness="1"
                        CornerRadius="5" Padding="12,8"
                        IsVisible="{Binding MensajeEsError}">
                    <TextBlock Text="{Binding MensajeEstado}"
                               Foreground="#F85149" FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Mensaje de éxito -->
                <Border Background="#0D2A1A" BorderBrush="#3FB950" BorderThickness="1"
                        CornerRadius="5" Padding="12,8"
                        IsVisible="{Binding MensajeEsExito}">
                    <TextBlock Text="{Binding MensajeEstado}"
                               Foreground="#3FB950" FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Botón enviar -->
                <Button Content="📤  Enviar Rutina"
                        Command="{Binding EnviarInvitacionCommand}"
                        IsEnabled="{Binding !Enviando}"
                        Classes="btn-primary"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
